<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eilya SDK Sample"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0D0D14"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test OTP and Chat SDKs"
            android:textSize="14sp"
            android:textColor="#6B6B80"
            android:layout_marginBottom="32dp" />

        <!-- OTP Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP Verification"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#7C3AED"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputPhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Phone number (e.g. +201012345678)"
            android:inputType="phone"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequestOtp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Request OTP"
            android:backgroundTint="#7C3AED"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutVerify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputOtpCode"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Enter OTP code"
                android:inputType="number"
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyOtp"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Verify"
                android:backgroundTint="#10B981" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtOtpStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#6B6B80"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp" />

        <!-- Chat Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Chat"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#3B82F6"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputChatMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Type a message..."
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendChat"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Send"
                android:backgroundTint="#3B82F6" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtChatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#6B6B80"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
